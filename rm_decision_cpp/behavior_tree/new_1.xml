<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4"
      main_tree_to_execute="BehaviorTree">
  <BehaviorTree ID="BehaviorTree">
    <ReactiveSequence>
      <SubRobotStatus topic_name="/robot_status"
                      robot_status="{robot_status}"/>
      <SubGameStatus topic_name="/game_status"
                     game_status="{game_status}"/>
      <SubArmors topic_name="/target_tracking"
                 armors="{armors}"/>
      <GetLocation topic_name="/chassis_odometry_gt"
                   robot_location="{robot_pose}"/>
      <EnemyPositionFilter enemy_position="{armors}"
                           alpha="0.2"
                           max_distance="1.0"
                           history_size="7"
                           zero_threshold="0.1"
                           min_output_interval="0.1"
                           confidence_half_life="1.0"
                           min_confidence="0.0"
                           filtered_position="{filtered_target}"/>
      <ConfidenceHysteresis target="{filtered_target}"
                            upper_threshold="0.5"
                            lower_threshold="0.2"
                            grace_period="2.5"
                            enable_hold_position="true"
                            current_confidence="{current_confidence}"
                            hysteresis_state="{hysteresis_state}"/>
      <AsyncFallback>
        <IsGameTime message="{game_status}"
                    game_progress="4"
                    lower_remain_time="0"
                    higher_remain_time="10000"/>
        <IsAttacked message="{robot_status}"/>
      </AsyncFallback>
      <IfThenElse>
        <IsStatusOK message="{robot_status}"
                    hp_threshold="160"
                    heat_threshold="0"
                    shot_threshold="10"/>
        <Sequence>
          <RobotControl stop_gimbal_scan="True"
                        chassis_spin_vel="0.0"
                        gimbal_big_yaw_vel="0.0"
                        gimbal_big_yaw_angle="0.0"
                        follow_gimbal_big="False"
                        chassis_vel_multi="1.0"
                        stop_chassis_vel_multi="True"
                        track_status="False"
                        perception_status="False"/>
          <LoadWaypoints waypoint_file="/home/sentry/Desktop/ros_ws/自己半场巡逻.csv"
                         frame_id="map"
                         waypoints="{waypoints_high}"
                         wait_times="{wait_times_high}"
                         total_waypoints="{total_wp_high}"
                         wp_idx="{wp_idx_high}"/>
          <KeepRunningUntilFailure>
            <Sequence>
              <GetCurrentWaypoint waypoints="{waypoints_high}"
                                  wait_times="{wait_times_high}"
                                  wp_idx="{wp_idx_high}"
                                  current_goal="{current_goal_high}"
                                  current_wait_sec="{current_wait_sec_high}"/>
              <ReactiveSequence>
                <PubNav2Goal goal_pose="{current_goal_high}"
                             frame_id="map"
                             min_pub_interval_ms="500"/>
                <WaitUntilReached goal_pose="{current_goal_high}"
                                  tolerance="0.5"/>
              </ReactiveSequence>
              <WaitDuration duration_sec="{current_wait_sec_high}"/>
              <NextWaypoint wp_idx="{wp_idx_high}"
                            total_waypoints="{total_wp_high}"/>
            </Sequence>
          </KeepRunningUntilFailure>
        </Sequence>
        <ForceSuccess>
          <Sequence>
            <CancelNavigation action_name="/navigate_to_pose"/>
            <RobotControl stop_gimbal_scan="True"
                          chassis_spin_vel="0.0"
                          gimbal_big_yaw_vel="0.0"
                          gimbal_big_yaw_angle="0.0"
                          follow_gimbal_big="true"
                          chassis_vel_multi="1.0"
                          stop_chassis_vel_multi="True"
                          track_status="True"
                          perception_status="False"/>
            <SendMyGoal name="NavigateToObservation"
                        my_goal_pose="0.1;0.0;0;0;0;-0.227012;0.973892"
                        action_name="/navigate_to_pose"
                        goal_id="5"
                        max_visits="10000"
                        stall_threshold="0.2"
                        stall_check_interval="2.0"
                        min_distance_for_stall="0.5"
                        out_robot_pose="{out_robot_pose}"/>
            <WaitUntilReached goal_pose="{out_robot_pose}"
                              tolerance="0.5"/>
            <Wait duration="5"/>
          </Sequence>
        </ForceSuccess>
      </IfThenElse>
    </ReactiveSequence>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Action ID="CancelNavigation">
      <input_port name="action_name"
                  default="/action_name"/>
    </Action>
    <Condition ID="ConfidenceHysteresis">
      <input_port name="target"
                  default="{filtered_target}"/>
      <input_port name="upper_threshold"
                  default="0.4"/>
      <input_port name="lower_threshold"
                  default="0.3"/>
      <input_port name="grace_period"
                  default="1.5"/>
      <input_port name="enable_hold_position"
                  default="true"/>
      <output_port name="current_confidence"
                   default="{current_confidence}"/>
      <output_port name="hysteresis_state"
                   default="{hysteresis_state}"/>
    </Condition>
    <Action ID="EnemyPositionFilter"
            editable="true">
      <input_port name="enemy_position"
                  default="{armors}"/>
      <input_port name="alpha"
                  default="0.3"/>
      <input_port name="max_distance"
                  default="1.5"/>
      <input_port name="history_size"
                  default="5"/>
      <input_port name="zero_threshold"
                  default="0.1"/>
      <input_port name="min_output_interval"
                  default="0.1"/>
      <input_port name="confidence_half_life"
                  default="1.0"/>
      <input_port name="min_confidence"
                  default="0.0"/>
      <output_port name="filtered_position"
                   default="{filtered_position}"/>
    </Action>
    <Action ID="GetCurrentWaypoint">
      <input_port name="waypoints"
                  default="{waypoints}"/>
      <input_port name="wait_times"
                  default="{wait_times}"/>
      <input_port name="wp_idx"
                  default="{wp_idx}"/>
      <output_port name="current_goal"
                   default="{current_goal}"/>
      <output_port name="current_wait_sec"
                   default="{current_wait}"/>
    </Action>
    <Action ID="GetLocation">
      <input_port name="topic_name"
                  default="/odometry"/>
      <output_port name="robot_location"
                   default="{robot_pose}"/>
    </Action>
    <Action ID="IsAttacked"
            editable="true">
      <input_port name="message"
                  default="{robot_status}"/>
    </Action>
    <Condition ID="IsGameTime"
               editable="true">
      <input_port name="message"
                  default="{game_status}"/>
      <input_port name="game_progress"
                  default="4"/>
      <input_port name="lower_remain_time"
                  default="0"/>
      <input_port name="higher_remain_time"
                  default="300"/>
    </Condition>
    <Condition ID="IsStatusOK"
               editable="true">
      <input_port name="message"
                  default="{robot_status}"/>
      <input_port name="hp_threshold"
                  default="100"/>
      <input_port name="heat_threshold"
                  default="350"/>
      <input_port name="shot_threshold"
                  default="0"/>
    </Condition>
    <Action ID="LoadWaypoints">
      <input_port name="waypoint_file"/>
      <input_port name="frame_id"
                  default="map"/>
      <output_port name="waypoints"
                   default="{waypoints}"/>
      <output_port name="wait_times"
                   default="{wait_times}"/>
      <output_port name="total_waypoints"
                   default="{total_wp}"/>
      <output_port name="wp_idx"
                   default="{wp_idx}"/>
    </Action>
    <Action ID="NextWaypoint">
      <inout_port name="wp_idx"
                  default="{wp_idx}"/>
      <input_port name="total_waypoints"
                  default="{total_wp}"/>
    </Action>
    <Action ID="PubNav2Goal"
            editable="true">
      <input_port name="goal_pose"/>
      <input_port name="frame_id"/>
      <input_port name="min_pub_interval_ms"/>
    </Action>
    <Action ID="RobotControl">
      <input_port name="stop_gimbal_scan"
                  default="True"/>
      <input_port name="chassis_spin_vel"
                  default="0.0"/>
      <input_port name="gimbal_big_yaw_vel"
                  default="1.0"/>
      <input_port name="gimbal_big_yaw_angle"
                  default="0.785"/>
      <input_port name="follow_gimbal_big"
                  default="true"/>
      <input_port name="chassis_vel_multi"
                  default="1.0"/>
      <input_port name="stop_chassis_vel_multi"
                  default="True"/>
      <input_port name="track_status"
                  default="false"/>
      <input_port name="perception_status"
                  default="True"/>
    </Action>
    <Action ID="SendMyGoal">
      <input_port name="my_goal_pose"
                  default="{best_goal}"/>
      <input_port name="action_name"
                  default="/navigate_to_pose"/>
      <input_port name="goal_id"
                  default="1"/>
      <input_port name="max_visits"
                  default="1"/>
      <input_port name="stall_threshold"
                  default="0.2"/>
      <input_port name="stall_check_interval"
                  default="2.0"/>
      <input_port name="min_distance_for_stall"
                  default="0.5"/>
      <output_port name="out_robot_pose"
                   default="{out_robot_pose}"/>
    </Action>
    <Action ID="SubArmors"
            editable="true">
      <input_port name="topic_name"
                  default="/detector/armors"/>
      <output_port name="armors"
                   default="{armors}"/>
    </Action>
    <Action ID="SubGameStatus"
            editable="true">
      <input_port name="topic_name"
                  default="game_status"/>
      <output_port name="game_status"
                   default="{game_status}"/>
    </Action>
    <Action ID="SubRobotStatus"
            editable="true">
      <input_port name="topic_name"
                  default="robot_status"/>
      <output_port name="robot_status"
                   default="{robot_status}"/>
    </Action>
    <Action ID="Wait"
            editable="true">
      <input_port name="duration"
                  default="3"/>
    </Action>
    <Action ID="WaitDuration">
      <input_port name="duration_sec"
                  default="5.0"/>
    </Action>
    <Action ID="WaitUntilReached">
      <input_port name="goal_pose"/>
      <input_port name="tolerance"
                  default="0.5"/>
    </Action>
  </TreeNodesModel>

</root>
